{
  "name": "@jsrs/plugin",
  "type": "module",
  "version": "0.1.0",
  "description": "",
  "license": "MIT",
  "homepage": "https://github.com/kermanx/js.rs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kermanx/js.rs.git"
  },
  "bugs": {
    "url": "https://github.com/kermanx/js.rs/issues"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "transform"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./astro": {
      "import": "./dist/astro.js"
    },
    "./rspack": {
      "import": "./dist/rspack.js"
    },
    "./vite": {
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "import": "./dist/webpack.js"
    },
    "./rollup": {
      "import": "./dist/rollup.js"
    },
    "./esbuild": {
      "import": "./dist/esbuild.js"
    },
    "./nuxt": {
      "import": "./dist/nuxt.js"
    },
    "./farm": {
      "import": "./dist/farm.js"
    },
    "./types": {
      "import": "./dist/types.js"
    },
    "./*": "./*"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "play": "npm -C playground run dev"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1",
    "@nuxt/kit": "^3",
    "@nuxt/schema": "^3",
    "esbuild": "*",
    "rollup": "^3",
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@farmfe/core": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "@jsrs/transpiler": "workspace:^",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@types/node": "^25.5.2",
    "bumpp": "^11.0.1",
    "nodemon": "^3.1.14",
    "rollup": "^4.60.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unplugin-utils": "^0.3.1",
    "vite": "^8.0.3",
    "webpack": "^5.105.4"
  }
}
