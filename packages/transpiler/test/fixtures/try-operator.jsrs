fn passthrough(x: Result<i32, string>) -> Result<i32, string> {
  let v = x?;
  Result::Ok(v)
}

fn try_then_method(a: Result<Boxed, string>) -> Result<i32, string> {
  let x = a?.inc();
  Result::Ok(x)
}

fn try_then_index(a: Result<(i32, i32), string>) -> Result<i32, string> {
  let x = a?[1];
  Result::Ok(x)
}

