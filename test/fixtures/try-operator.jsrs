fn passthrough(x: Result<number, string>) -> Result<number, string> {
  let v = x?;
  Result::Ok(v)
}

fn try_then_method(a: Result<Boxed, string>) -> Result<number, string> {
  let x = a?.inc();
  Result::Ok(x)
}

fn try_then_index(a: Result<(number, number), string>) -> Result<number, string> {
  let x = a?[1];
  Result::Ok(x)
}

